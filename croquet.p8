pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
-- By Joel Geddert
-- License: CC BY-NC-SA 4.0

--
-- Debug options
--

-- DEBUG_NO_DRAW_TOPS = true
-- DEBUG_DRAW_DOTS = true

--
-- Consts
--

-- WIDTH, HEIGHT = 256, 128
WIDTH, HEIGHT = 384, 192

CX = WIDTH \ 2
CY = HEIGHT \ 2

PX = 32
W1X = 64
W2X = 96
W3X = CX - 48
WY = CY - 48

WICKETS = {
	{PX, CY, pole=true},
	{W1X, CY},
	{W2X, CY},
	{W3X, HEIGHT - WY},
	{CX, CY},
	{WIDTH - W3X, HEIGHT - WY},
	{WIDTH - W2X, CY},
	{WIDTH - W1X, CY},
	{WIDTH - PX, CY, pole=true},
	{WIDTH - W1X, CY, hidden=true},
	{WIDTH - W2X, CY, hidden=true},
	{WIDTH - W3X, WY},
	{CX, CY, hidden=true},
	{W3X, WY},
	{W2X, CY, hidden=true},
	{W1X, CY, hidden=true},
	{PX, CY, pole=true, hidden=true},
}

PALETTES = {
	-- main, dark, light
	{[8]=12, [2]=1, [14]=6}, -- Blue
	{[8]=8, [2]=2, [14]=14}, -- Red
	{[8]=0, [2]=5, [14]=5}, -- Black
	{[8]=10, [2]=9, [14]=6}, -- Yellow

	{[8]=1, [2]=5, [14]=12}, -- Dark blue
	-- {[8]=3, [2]=5, [14]=11}, -- Green

	{[8]=9, [2]=4, [14]=10}, -- Orange
}

--
-- Globals
--

camera_x = 0
camera_y = CY

--
-- Utility functions
--

function round(val)
	return flr(val + 0.5)
end

function clip_num(val, minval, maxval)
	return max(minval, min(maxval, val))
end

function _init()
	balls = {}
	local idx = 1  -- DEBUG
	for p in all(PALETTES) do
		idx += 1
		add(balls, {
			-- x=nil,
			-- y=nil,
			x = idx*8, -- DEBUG
			y = 16, -- DEBUG
			vx=0,
			vy=0,
			color=p[8],
			palette=p,
		})
	end
end

function _update60()
-- function _update()


	if (btn(0)) camera_x -= 2  -- left
	if (btn(1)) camera_x += 2  -- right
	if (btn(2)) camera_y -= 2  -- up
	if (btn(3)) camera_y += 2  -- down

	camera_x = clip_num(camera_x, 64, WIDTH-64)
	camera_y = clip_num(camera_y, 64, HEIGHT-64)





	cpu_update = stat(1)
end

function _draw()

	-- cls(3)
	cls()
	camera(camera_x - 64, camera_y - 64)

	-- pal({[3]=139,[11]=138}, 1)
	-- pal({[13]=139,[15]=138}, 1)

	-- fillp(0b0101101001011010)
	-- rectfill(0, 0, 128, 128, 0x3B)

	-- Draw field
	for y=0,(HEIGHT\16) do
		for x=0,(WIDTH\16) do
			fillp(0b0101101001011010)
			if (x % 2 == 0 and y % 2 == 1) fillp(0xFFFF)
			if (x % 2 == 1 and y % 2 == 0) fillp(0x0000)
			-- rectfill(x*16 - 8, y*16 - 8, x*16 + 8, y*16 + 8, 0x3B)
			rectfill(x*16 - 8, y*16 - 8, x*16 + 8, y*16 + 8, 0xDF)
		end
	end
	fillp()

	rect(0, 0, WIDTH - 1, HEIGHT - 1, 7)

	-- Draw wicket & pole bases
	palt(0, false)
	palt(3, true)
	for w in all(WICKETS) do
		if not w.hidden then
			if w.pole then
				spr(39, w[1]-3, w[2]-7)
			else
				local x, y = w[1]-4, w[2]-1
				spr(17, x, y-8)
				spr(33, x, y)
			end
		end
	end
	-- for p in all(POLES) do
	-- 	-- spr(19, p[1]-4, p[2]-4)
	-- 	spr(39, p[1]-3, p[2]-7)
	-- end
	palt()

	-- TODO: draw arrow on next wicket

	-- TODO: from here down, draw in Y order

	-- Draw balls
	for ball in all(balls) do
		if ball.x and ball.y then
			-- pal(8, ball.color)
			pal(ball.palette)
			spr(4, ball.x, ball.y)
		end
	end
	pal()

	-- Draw wicket & pole tops
	if not DEBUG_NO_DRAW_TOPS then
		palt(0, false)
		palt(3, true)
		for w in all(WICKETS) do
			if not w.hidden then
				if w.pole then
					spr(23, w[1]-3, w[2]-7)
				else
					local x, y = w[1]-4, w[2]-1
					spr(18, x, y-8)
					spr(34, x, y)
				end
			end
		end
		-- for p in all(POLES) do
		-- 	-- spr(19, p[1]-4, p[2]-4)
		-- 	spr(23, p[1]-3, p[2]-7)
		-- end
		palt()
	end

	if DEBUG_DRAW_DOTS then
		for w in all(WICKETS) do
			if w.pole then
				rectfill(w[1], w[2], w[1], w[2], 8)
			else
				rectfill(w[1], w[2] - 5, w[1], w[2] - 5, 9)
				rectfill(w[1], w[2] + 4, w[1], w[2] + 4, 9)
			end
		end
	end

	-- Set display palette at end, so it doesn't get wiped out by any pal() calls
	-- pal({[13]=139,[15]=138}, 1)
	pal({[13]=139,[15]=3}, 1)
	-- pal({[13]=3,[15]=138}, 1)



	camera()
	cursor(1, 1, 8)
	-- print('mem:' .. stat(0))
	local cpu = stat(1)
	-- local cpu_draw = cpu - cpu_update
	-- print('cpu:' .. round(cpu * 100) .. '=' .. round(cpu_update * 100) .. '+' .. round(cpu_draw * 100))
	print(round(cpu * 100))
end

